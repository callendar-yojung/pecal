{
  "name": "callendar-monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:web": "pnpm --filter ./apps/web dev",
    "dev:desktop": "pnpm --filter ./apps/desktop tauri:dev",
    "dev:desktop:web": "pnpm --filter ./apps/desktop dev",
    "dev:mobile": "pnpm --filter ./apps/mobile start",
    "dev:mobile:android": "pnpm --filter ./apps/mobile android",
    "dev:mobile:ios": "pnpm --filter ./apps/mobile ios",
    "dev:mobile:web": "pnpm --filter ./apps/mobile web",
    "build:web": "pnpm --filter ./apps/web build",
    "build:desktop": "pnpm --filter ./apps/desktop build",
    "build:desktop:tauri": "pnpm --filter ./apps/desktop tauri:build",
    "build": "pnpm run build:web",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4"
  },
  "dependencies": {
    "pnpm": "^10.30.1"
  },
  "pnpm": {
    "overrides": {
      "@aws-sdk/xml-builder>fast-xml-parser": "5.3.8",
      "@swagger-api/apidom-reference>minimatch": "10.2.4",
      "brace-expansion": "1.1.13",
      "dompurify": "3.3.3",
      "fast-xml-parser": "5.3.8",
      "glob>minimatch": "3.1.4",
      "immutable": "3.8.3",
      "minimatch": "10.2.4",
      "nodemailer": "6.10.0",
      "picomatch": "4.0.4",
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "rollup": "4.59.0",
      "swagger-client": "3.37.0",
      "tar": "7.5.10"
    }
  }
}
