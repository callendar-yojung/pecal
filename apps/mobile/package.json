    "@repo/api-client": "workspace:*",
    "@repo/utils": "workspace:*",
    "autoprefixer": "^10.4.23",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.10",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
