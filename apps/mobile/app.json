{
  "expo": {
    "name": "피켈",
    "slug": "pecal-mobile",
    "version": "1.0.2",
    "scheme": "myapp",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon-ios.png",
      "bundleIdentifier": "com.pecal.mobile",
      "buildNumber": "1.0.2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
