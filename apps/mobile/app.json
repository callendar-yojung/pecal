      },
      "package": "com.pecal.mobile"
    },
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "expo-notifications",
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee18ce25-67d9-45cd-a401-ba3d259ada83"
      }
    },
    "owner": "tlswlfk"
  }
