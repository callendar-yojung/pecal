{
  "expo": {
    "name": "피켈",
    "slug": "pecal-mobile",
    "version": "1.0.4",
    "scheme": "myapp",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/last.png",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/last.png",
      "bundleIdentifier": "com.pecal.mobile",
      "buildNumber": "19",
      "infoPlist": {
        "NSCameraUsageDescription": "사진을 촬영하여 일정에 첨부하기 위해 사용됩니다.",
        "NSPhotoLibraryUsageDescription": "일정에 사진과 동영상을 첨부하기 위해 사용됩니다.",
        "NSPhotoLibraryAddUsageDescription": "첨부한 사진과 동영상을 저장하기 위해 사용됩니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/image.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.pecal.mobile"
    },
    "splash": {
      "image": "./assets/last.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "plugins": [
      "expo-notifications",
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee18ce25-67d9-45cd-a401-ba3d259ada83"
      }
    },
    "owner": "tlswlfk"
  }
}
