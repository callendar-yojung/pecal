require "xcodeproj"
require "json"

default_platform(:ios)

def upload_to_testflight_with_retry(params, max_attempts: 3, wait_seconds: 20)
  attempts = 0
  begin
    attempts += 1
    upload_to_testflight(params)
  rescue => error
    if attempts < max_attempts
      UI.important("upload_to_testflight failed (attempt #{attempts}/#{max_attempts}): #{error.message}")
      UI.important("Retrying in #{wait_seconds}s...")
      sleep(wait_seconds)
      retry
    end
    raise error
  end
end

def load_app_store_api_credentials!
  raw_key = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT").strip

  key_content =
    if raw_key.include?("BEGIN PRIVATE KEY")
      raw_key.gsub("\n", "
")
    else
      require "base64"
      Base64.strict_decode64(raw_key)
    end

  require "tmpdir"
  key_id = ENV.fetch("APP_STORE_CONNECT_KEY_ID")
  issuer_id = ENV.fetch("APP_STORE_CONNECT_ISSUER_ID")
  key_path = File.join(Dir.tmpdir, "AuthKey_#{key_id}.p8")
  File.write(key_path, key_content)

  api_key = app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
    issuer_id: issuer_id,
    key_content: key_content,
    is_key_content_base64: false
  )
  [api_key, key_path, key_id, issuer_id]
rescue ArgumentError
  UI.user_error!("APP_STORE_CONNECT_API_KEY_CONTENT must be a .p8 private key text (or base64-encoded .p8 text)")
end

def setup_ci_keychain_if_needed
  return unless ENV["CI"] == "true"
  return if ENV["KEYCHAIN_PASSWORD"].to_s.empty?

  keychain_name = ENV.fetch("KEYCHAIN_NAME", "ci.keychain")
  create_keychain(
    name: keychain_name,
    password: ENV["KEYCHAIN_PASSWORD"],
    default_keychain: true,
    unlock: true,
    timeout: 3600,
    lock_when_sleeps: true
  )
  ENV["KEYCHAIN_PATH"] = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
end

platform :ios do
  desc "Build iOS and upload to TestFlight"
  lane :beta do |options|
    desired_xcode = ENV["XCODE_PATH"] || "/Applications/Xcode_16.4.app"
    fallback_xcode = "/Applications/Xcode.app"
    xcode_select(File.exist?(desired_xcode) ? desired_xcode : fallback_xcode)
    setup_ci_keychain_if_needed
    keychain_path = ENV["KEYCHAIN_PATH"] || "/Users/runner/Library/Keychains/login.keychain-db"
    if ENV["KEYCHAIN_PASSWORD"] && !ENV["KEYCHAIN_PASSWORD"].empty?
      unlock_keychain(
        path: keychain_path,
        password: ENV["KEYCHAIN_PASSWORD"]
      )
    end
    api_key, auth_key_path, auth_key_id, auth_issuer_id = load_app_store_api_credentials!
    team_id = ENV.fetch("APPLE_TEAM_ID", ENV.fetch("APP_STORE_CONNECT_TEAM_ID"))

    if ENV["MATCH_GIT_URL"] && !ENV["MATCH_GIT_URL"].empty?
      match_args = {
        type: "appstore",
        readonly: ENV.fetch("MATCH_READONLY", "true") == "true",
        app_identifier: [
          "com.pecal.mobile",
          "com.pecal.mobile.PecalWidgetExtension"
        ]
      }
      if ENV["KEYCHAIN_PASSWORD"] && !ENV["KEYCHAIN_PASSWORD"].empty?
        match_args[:keychain_name] = ENV["KEYCHAIN_NAME"]
        match_args[:keychain_password] = ENV["KEYCHAIN_PASSWORD"]
      end
      match(match_args)
    end
    provisioning_profiles = Actions.lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
    use_manual_signing = provisioning_profiles && !provisioning_profiles.empty?

    # 태그에서 버전 추출
    tag_name = ENV["GITHUB_REF_NAME"]
    if tag_name && tag_name.start_with?("ios-v")
      begin
        version_from_tag = tag_name.gsub("ios-v", "")
        UI.message("Force syncing everything to version #{version_from_tag}...")

        # 1. app.json 수정 (Expo 빌드 페이즈 대응)
        if File.exist?("app.json")
          app_json = JSON.parse(File.read("app.json"))
          app_json["expo"]["version"] = version_from_tag
          app_json["expo"]["ios"]["buildNumber"] = version_from_tag if app_json["expo"]["ios"]
          File.write("app.json", JSON.pretty_generate(app_json))
          UI.success("Updated app.json version to #{version_from_tag}")
        end
        
        # 2. xcodeproj 빌드 설정 수정
        project_path = "ios/PecalMobile.xcodeproj"
        if File.exist?(project_path)
          project = Xcodeproj::Project.open(project_path)
          project.targets.each do |target|
            target.build_configurations.each do |config|
              config.build_settings["MARKETING_VERSION"] = version_from_tag
              config.build_settings["CURRENT_PROJECT_VERSION"] = version_from_tag
            end
          end
          project.save
          UI.success("Updated .xcodeproj build settings.")
        end

        # 3. Info.plist 수정
        plists = ["ios/PecalMobile/Info.plist", "ios/PecalWidgetExtension/Info.plist"]
        plists.each do |plist|
          if File.exist?(plist)
            set_info_plist_value(path: plist, key: "CFBundleShortVersionString", value: version_from_tag)
            set_info_plist_value(path: plist, key: "CFBundleVersion", value: version_from_tag)
          end
        end
      rescue => e
        UI.error("Failed to sync versions: #{e.message}")
      end
    end

    # 모든 타겟의 코드 사이닝 설정을 수동으로 강제 및 프로필 매핑
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/PecalMobile.xcodeproj",
      targets: ["PecalMobile"],
      profile_name: provisioning_profiles["com.pecal.mobile"]
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/PecalMobile.xcodeproj",
      targets: ["PecalWidgetExtensionExtension"],
      profile_name: provisioning_profiles["com.pecal.mobile.PecalWidgetExtension"]
    )

    build_app(
      workspace: "ios/PecalMobile.xcworkspace",
      scheme: "PecalMobile",
      configuration: "Release",
      clean: true,
      verbose: true,
      silent: false,
      export_method: "app-store",
      export_options: {
        signingStyle: use_manual_signing ? "manual" : "automatic",
        teamID: team_id,
        provisioningProfiles: provisioning_profiles
      }.compact,
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        "DEVELOPMENT_TEAM=#{team_id}",
        "-allowProvisioningUpdates",
        "-authenticationKeyPath #{auth_key_path}",
        "-authenticationKeyID #{auth_key_id}",
        "-authenticationKeyIssuerID #{auth_issuer_id}"
      ].join(" "),
      output_directory: "build/ios",
      output_name: "PecalMobile.ipa"
    )

    upload_to_testflight_with_retry(
      {
        api_key: api_key,
        app_identifier: "com.pecal.mobile",
        skip_waiting_for_build_processing: true,
        changelog: (options[:changelog] || ENV["CHANGELOG"]),
        distribute_external: false
      },
      max_attempts: 3,
      wait_seconds: 20
    )
  end

  desc "Submit latest build to App Store review"
  lane :release do
    desired_xcode = ENV["XCODE_PATH"] || "/Applications/Xcode_16.4.app"
    fallback_xcode = "/Applications/Xcode.app"
    xcode_select(File.exist?(desired_xcode) ? desired_xcode : fallback_xcode)
    setup_ci_keychain_if_needed
    keychain_path = ENV["KEYCHAIN_PATH"] || "/Users/runner/Library/Keychains/login.keychain-db"
    if ENV["KEYCHAIN_PASSWORD"] && !ENV["KEYCHAIN_PASSWORD"].empty?
      unlock_keychain(
        path: keychain_path,
        password: ENV["KEYCHAIN_PASSWORD"]
      )
    end
    api_key, = load_app_store_api_credentials!

    upload_to_app_store(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: false,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Local build without App Store Connect (no upload)"
  lane :local_build do
    desired_xcode = ENV["XCODE_PATH"] || "/Applications/Xcode_16.4.app"
    fallback_xcode = "/Applications/Xcode.app"
    xcode_select(File.exist?(desired_xcode) ? desired_xcode : fallback_xcode)
    setup_ci_keychain_if_needed
    keychain_path = ENV["KEYCHAIN_PATH"] || "/Users/runner/Library/Keychains/login.keychain-db"
    if ENV["KEYCHAIN_PASSWORD"] && !ENV["KEYCHAIN_PASSWORD"].empty?
      unlock_keychain(
        path: keychain_path,
        password: ENV["KEYCHAIN_PASSWORD"]
      )
    end

    if ENV["MATCH_GIT_URL"] && !ENV["MATCH_GIT_URL"].empty?
      match_args = {
        type: "appstore",
        readonly: ENV.fetch("MATCH_READONLY", "true") == "true",
        app_identifier: [
          "com.pecal.mobile",
          "com.pecal.mobile.PecalWidgetExtension"
        ]
      }
      if ENV["KEYCHAIN_PASSWORD"] && !ENV["KEYCHAIN_PASSWORD"].empty?
        match_args[:keychain_name] = ENV["KEYCHAIN_NAME"]
        match_args[:keychain_password] = ENV["KEYCHAIN_PASSWORD"]
      end
      match(match_args)
    end
    provisioning_profiles = Actions.lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING]
    use_manual_signing = provisioning_profiles && !provisioning_profiles.empty?

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/PecalMobile.xcodeproj",
      targets: ["PecalMobile"],
      profile_name: provisioning_profiles["com.pecal.mobile"]
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/PecalMobile.xcodeproj",
      targets: ["PecalWidgetExtensionExtension"],
      profile_name: provisioning_profiles["com.pecal.mobile.PecalWidgetExtension"]
    )

    build_app(
      workspace: "ios/PecalMobile.xcworkspace",
      scheme: "PecalMobile",
      configuration: "Release",
      clean: true,
      verbose: true,
      silent: false,
      export_method: "app-store",
      export_options: {
        signingStyle: use_manual_signing ? "manual" : "automatic",
        provisioningProfiles: provisioning_profiles
      }.compact,
      xcargs: [
        "CODE_SIGN_STYLE=Manual"
      ].join(" "),
      output_directory: "build/ios",
      output_name: "PecalMobile.ipa"
    )
  end
end
