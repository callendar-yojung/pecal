require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']
  
  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'PecalMobile' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # Expo Router's LinkPreview imports a header removed in recent react-native-screens.
    # Provide a tiny compatibility stub so the pod build doesn't fail when the header is absent.
    require 'fileutils'
    dismiss_stub = <<~EOF
      #ifndef RNSDismissibleModalProtocol_h
      #define RNSDismissibleModalProtocol_h
      #import <Foundation/Foundation.h>
      @protocol RNSDismissibleModalProtocol <NSObject>
      @optional
      - (void)requestDismissal;
      @end
      #endif
    EOF

    tabbar_stub = <<~EOF
      #ifndef RNSTabBarController_h
      #define RNSTabBarController_h
      #import <UIKit/UIKit.h>
      @interface RNSTabBarController : UITabBarController
      @end
      #endif
    EOF

    %w[Public Private].each do |scope|
      headers_dir = File.join(installer.sandbox.root, "Headers", scope, "RNScreens")
      FileUtils.mkdir_p(headers_dir)
      dismiss_path = File.join(headers_dir, "RNSDismissibleModalProtocol.h")
      tabbar_path = File.join(headers_dir, "RNSTabBarController.h")
      File.write(dismiss_path, dismiss_stub) unless File.exist?(dismiss_path)
      File.write(tabbar_path, tabbar_stub) unless File.exist?(tabbar_path)
    end

    # Provide runtime stubs for removed RNScreens types so Expo Router compiles.
    compat_dir = File.expand_path("../RNSScreensCompat", __dir__)
    FileUtils.mkdir_p(compat_dir)
    compat_file = File.join(compat_dir, "RNSScreensCompatStub.m")
    unless File.exist?(compat_file)
      File.write(compat_file, <<~EOS)
        #import <UIKit/UIKit.h>
        #import <RNScreens/RNSScreen.h>

        @interface RNSBottomTabsScreenComponentView : UIView
        @property(nonatomic, copy) NSString *tabKey;
        - (UIViewController *)reactViewController;
        @end
        @implementation RNSBottomTabsScreenComponentView
        - (UIViewController *)reactViewController { return nil; }
        @end

        @interface RNSBottomTabsHostComponentView : UIView
        - (UITabBarController *)controller;
        @end
        @implementation RNSBottomTabsHostComponentView
        - (UITabBarController *)controller { return nil; }
        @end

        @interface RNSTabBarController : UITabBarController @end
        @implementation RNSTabBarController @end

        @interface RNSScreenStackView (PecalCompat)
        @property(nonatomic, copy) NSArray<NSString *> *screenIds;
        @property(nonatomic, copy) NSArray<UIView *> *reactSubviews;
        @end
        @implementation RNSScreenStackView (PecalCompat)
        - (NSArray<NSString *> *)screenIds { return @[]; }
        - (void)setScreenIds:(NSArray<NSString *> *)value {}
        - (NSArray<UIView *> *)reactSubviews { return @[]; }
        - (void)setReactSubviews:(NSArray<UIView *> *)value {}
        @end

        @interface RNSScreenView (PecalCompat)
        @property(nonatomic, copy) NSString *screenId;
        @end
        @implementation RNSScreenView (PecalCompat)
        - (NSString *)screenId { return nil; }
        - (void)setScreenId:(NSString *)value {}
        @end
      EOS
    end

    expo_head = installer.pods_project.targets.find { |t| t.name == "ExpoHead" }
    if expo_head && !expo_head.source_build_phase.files_references.any? { |fr| fr.path&.end_with?("RNSScreensCompatStub.m") }
      group = installer.pods_project.main_group.find_subpath("Compatibility Stubs", true)
      file_ref = group.new_file(compat_file)
      expo_head.source_build_phase.add_file_reference(file_ref)
    end

    # Patch Expo Router LinkPreview to add forward declarations for removed RNS types.
    link_preview = File.expand_path("../node_modules/expo-router/ios/LinkPreview/LinkPreviewNativeNavigation.mm", __dir__)
    if File.exist?(link_preview)
      content = File.read(link_preview)
      unless content.include?("PECAL_RNS_COMPAT")
        compat = <<~'COMPAT'
        // PECAL_RNS_COMPAT
        #ifndef PECAL_RNS_COMPAT
        #define PECAL_RNS_COMPAT
        @interface RNSBottomTabsScreenComponentView : UIView
        @property(nonatomic, copy) NSString *tabKey;
        - (UIViewController *)reactViewController;
        @end
        @interface RNSBottomTabsHostComponentView : UIView
        - (UITabBarController *)controller;
        @end
        @interface RNSTabBarController : UITabBarController @end
        @interface RNSScreenStackView (PecalCompat)
        @property(nonatomic, copy) NSArray<NSString *> *screenIds;
        @property(nonatomic, copy) NSArray<UIView *> *reactSubviews;
        @end
        @interface RNSScreenView (PecalCompat)
        @property(nonatomic, copy) NSString *screenId;
        @end
        #endif
        COMPAT
        patched = content.sub('#import <RNScreens/RNSScreenStack.h>', "#import <RNScreens/RNSScreenStack.h>\n#{compat}")
        File.write(link_preview, patched)
      end
    end
  end
end
